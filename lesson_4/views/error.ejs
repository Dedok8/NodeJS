<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
  </head>
  <body>
    <header>
      <div class="header__container">
        <h2>Error</h2>
      </div>
    </header>

    <main>
      <div class="book-info">
        <h1><%= message %></h1>
        <p><strong>Error Code:</strong> <%= error.status %></p>
        <% if (error.stack) { %>
          <p><strong>Details:</strong></p>
          <pre style="background-color: #f0f0f0; padding: 10px; border-radius: 4px; overflow-x: auto;"><%= error.stack %></pre>
        <% } %>
        <p style="margin-top: 20px;"><a href="/">← Back to Home</a></p>
      </div>
    </main>

  </body>
</html>
