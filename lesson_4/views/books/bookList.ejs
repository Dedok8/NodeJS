<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <header>
    <%- include('../components/header', { activePage: 'books' }) %>
  </header>

  <main>
    <h1><%= title %></h1>

    <form method="GET" action="/books">
      <input type="text" name="author" placeholder="Search by author" value="<%= typeof author !== 'undefined' ? author : '' %>">
      <input type="number" name="year" placeholder="Filter by year" value="<%= typeof year !== 'undefined' ? year : '' %>">
      <button type="submit">Search</button>
    </form>

    <% if (books.length === 0) { %>
      <p>No books found. <a href="/books/create">Add first book →</a></p>
    <% } else { %>
      <ul>
        <% books.forEach(book => { %>
          <li>
            <strong><%= book.title %></strong> — <%= book.author %> (<%= book.year %>)
            <div style="margin-top: 10px;">
              <a href="/books/<%= book.id %>">View</a> |
              <a href="/books/edit/<%= book.id %>">Edit</a>
              <form action="/books/<%= book.id %>" method="POST" style="display:inline">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit">Delete</button>
              </form>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <p style="margin-top: 30px;"><a href="/books/create">+ Add new book</a></p>
  </main>


</body>
</html>